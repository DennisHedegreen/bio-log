{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bio Log TID Entry",
  "type": "object",
  "required": ["date", "status", "photos", "scores", "observation", "protocol", "source"],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}$"
    },
    "status": {
      "type": "string",
      "enum": ["start", "normal", "gap", "restart-baseline", "low-confidence", "mobile-intake", "manual-rescue"]
    },
    "photos": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scores": {
      "type": "object",
      "required": ["water_clarity", "visible_life", "smell_intensity", "surface_activity", "sediment_change", "color_shift"],
      "properties": {
        "water_clarity": { "type": "integer", "minimum": 1, "maximum": 10 },
        "visible_life": { "type": "integer", "minimum": 1, "maximum": 10 },
        "smell_intensity": { "type": "integer", "minimum": 1, "maximum": 10 },
        "surface_activity": { "type": "integer", "minimum": 1, "maximum": 10 },
        "sediment_change": { "type": "integer", "minimum": 1, "maximum": 10 },
        "color_shift": { "type": "integer", "minimum": 1, "maximum": 10 }
      }
    },
    "observation": {
      "type": "object",
      "required": ["method", "quality", "confidence"],
      "properties": {
        "method": { "type": "string" },
        "quality": { "type": "string" },
        "confidence": { "type": "string", "enum": ["low", "medium", "high", "unknown"] },
        "notes": { "type": "string" }
      }
    },
    "protocol": {
      "type": "object",
      "required": ["workflow", "gap_days_before", "archive_status"],
      "properties": {
        "workflow": { "type": "string" },
        "gap_days_before": { "type": "integer", "minimum": 0 },
        "archive_status": { "type": "string" },
        "same_day_entry": { "type": "boolean" },
        "protocol_status": { "type": "string" }
      }
    },
    "source": {
      "type": "object",
      "required": ["log"],
      "properties": {
        "log": { "type": "string" },
        "image": { "type": "string" },
        "issue": { "type": ["integer", "null"] },
        "github_attachment": { "type": ["string", "null"] }
      }
    }
  }
}
